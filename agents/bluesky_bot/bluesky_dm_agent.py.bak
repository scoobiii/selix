#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
SELIX Bluesky DM Agent v4.1
- API correta: client.chat.bsky.convo.*
- Envia resposta real via send_message_to_conversation
- SELIX score calculado em tempo real
- Resposta dinâmica com parâmetros atuais
"""

import os
import sys
import time
import logging
from datetime import datetime, timezone
from dotenv import load_dotenv
from atproto import Client

# ─── LOGGING ────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)
log = logging.getLogger("selix-bot")

# ─── CONFIG ─────────────────────────────────────────────────────────────────
POLLING_INTERVAL = 30          # segundos entre cada poll
MAX_RESPONDIDAS  = 10_000      # limite de cache em memória


# ─── SELIX SCORE TEMPO REAL ──────────────────────────────────────────────────
def calcular_selix(ipca=4.48, roe=31.23, selic_bcb=14.50,
                   r_star=3.50, phi=1.39, delta=4.50):
    r1 = 9.99
    r2 = roe * 0.95
    r3 = ipca + 5.00
    piso = r_star * phi + delta
    s_star = max(piso, min(r1, r2, r3))
    desvio = round(selic_bcb - s_star, 2)
    score  = max(0.0, round(10 - 2 * max(0, desvio), 1))
    custo  = round(6.8 * desvio / 100 * 1_000, 0)   # R$ bilhões
    return {
        "s_star"  : round(s_star, 2),
        "selic"   : selic_bcb,
        "desvio"  : desvio,
        "score"   : score,
        "custo_bi": int(custo),
        "ig"      : s_star <= 9.99,
    }


def montar_resposta(r: dict) -> str:
    rating = (
        "🟢 ÓTIMO"   if r["score"] >= 9 else
        "🟡 BOM"     if r["score"] >= 7 else
        "🟠 ATENÇÃO" if r["score"] >= 5 else
        "🔴 CRÍTICO" if r["score"] >= 3 else
        "🚨 EMERGÊNCIA"
    )
    ig = "✅ Investment Grade possível" if r["ig"] else "❌ IG bloqueado"
    return (
        f"📊 SELIX — Taxa Selic Ótima\n"
        f"{'─'*32}\n"
        f"🎯 Selic ótima (s*):  {r['s_star']}%\n"
        f"📉 Selic BCB atual:   {r['selic']}%\n"
        f"⚠️  Desvio:           +{r['desvio']} pp\n"
        f"💸 Custo fiscal:      R$ {r['custo_bi']} bi/ano\n"
        f"{'─'*32}\n"
        f"📈 Score: {r['score']}/10 — {rating}\n"
        f"{ig}\n"
        f"🔬 Prova: Z3 SMT + Lean 4\n"
        f"🌾 Etanol: E30→E32 (Brent >US$100)\n"
        f"🔗 github.com/scoobiii/selix"
    )


# ─── BOT ─────────────────────────────────────────────────────────────────────
def main():
    load_dotenv()
    username = os.getenv("BLUESKY_USERNAME")
    password = os.getenv("BLUESKY_APP_PASSWORD")

    if not username or not password:
        log.error("Configure BLUESKY_USERNAME e BLUESKY_APP_PASSWORD no .env")
        sys.exit(1)

    client = Client()
    client.login(username, password)
    log.info(f"✅ Conectado: @{client.me.handle} ({client.me.display_name})")

    respondidas: set = set()   # cache de message IDs já respondidos
    total = 0

    log.info(f"🔄 Polling a cada {POLLING_INTERVAL}s — Ctrl+C para parar")

    while True:
        try:
            # ── Busca lista de conversas ─────────────────────────────────────
            resp = client.chat.bsky.convo.list_convos({"limit": 20})
            convos = resp.convos or []

            for convo in convos:
                convo_id = convo.id

                # ── Mensagens da conversa ────────────────────────────────────
                msgs_resp = client.chat.bsky.convo.get_messages(
                    {"convoId": convo_id, "limit": 10}
                )
                mensagens = msgs_resp.messages or []

                for msg in mensagens:
                    msg_id     = msg.id
                    sender_did = msg.sender.did if hasattr(msg.sender, "did") else ""
                    texto      = msg.text if hasattr(msg, "text") else ""

                    # Ignora: já respondida, própria mensagem, sem texto
                    if msg_id in respondidas:
                        continue
                    if sender_did == client.me.did:
                        respondidas.add(msg_id)
                        continue
                    if not texto.strip():
                        respondidas.add(msg_id)
                        continue

                    # ── Gera e envia resposta ────────────────────────────────
                    selix = calcular_selix()
                    resposta = montar_resposta(selix)

                    try:
                        client.chat.bsky.convo.send_message(
                            {
                                "convoId": convo_id,
                                "message": {"text": resposta},
                            }
                        )
                        respondidas.add(msg_id)
                        total += 1

                        # Limpa cache se ficar grande
                        if len(respondidas) > MAX_RESPONDIDAS:
                            respondidas = set(list(respondidas)[-5_000:])

                        handle = getattr(msg.sender, "handle", sender_did[:12])
                        log.info(
                            f"📨 DM de @{handle}: {texto[:60]!r} → resposta enviada "
                            f"(score={selix['score']}, s*={selix['s_star']}%) "
                            f"[total={total}]"
                        )

                    except Exception as e:
                        log.warning(f"Falha ao enviar para {convo_id}: {e}")
                        respondidas.add(msg_id)   # evita retry infinito

        except KeyboardInterrupt:
            log.info(f"\n🛑 Bot encerrado — {total} respostas enviadas.")
            break

        except Exception as e:
            log.error(f"Erro no loop principal: {e}")

        time.sleep(POLLING_INTERVAL)


if __name__ == "__main__":
    main()
