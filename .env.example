# SELIX v4.0 – Configuração (template – não contém credenciais reais)

# Banco de dados
SELIX_DB_PATH=/app/selix.db

# Worker
WORKER_INTERVAL_SEC=300
LOG_LEVEL=INFO

# API externas – obtenha sua chave em https://oilpriceapi.com
OILPRICEAPI_KEY=coloque_sua_chave_aqui

# Bluesky – crie uma senha de aplicativo em https://bsky.app/settings/app-passwords
BLUESKY_USERNAME=seu_usuario.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
